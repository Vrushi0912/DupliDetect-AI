# ─── DupliDetect — React Frontend Environment Variables ───────────────────────
#
# Copy this file to `.env.local` and fill in your values.
# Variables prefixed with REACT_APP_ are automatically bundled by CRA.
#
# ─── Backend API ──────────────────────────────────────────────────────────────
# Local dev: leave blank — apiClient.js auto-resolves to http://localhost:8000
# Production: set to your deployed FastAPI URL (e.g. https://api.duplidetect.com)
REACT_APP_API_URL=

# ─── Firebase ─────────────────────────────────────────────────────────────────
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
